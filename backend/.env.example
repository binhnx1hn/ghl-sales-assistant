# GoHighLevel Sales Assistant - Backend

# Environment
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here
GHL_BASE_URL=https://services.leadconnectorhq.com

# API Security
API_SECRET_KEY=change_this_to_a_random_secret_key
ALLOWED_ORIGINS=chrome-extension://your_extension_id,http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Phase 2A — AI Social Research + Email Drafter
# Get OpenAI API key at: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Get Serper.dev API key at: https://serper.dev (free tier: 2500 queries/month)
SERPER_API_KEY=your_serper_api_key_here

# Email drafter defaults (used when client doesn't pass these in the request)
DEFAULT_SENDER_NAME=Mai Bui
DEFAULT_SENDER_COMPANY=Your Company Name
DEFAULT_PITCH=We help businesses save time with smart CRM automation
