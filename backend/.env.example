# GoHighLevel Sales Assistant - Backend

# Environment
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here
GHL_BASE_URL=https://services.leadconnectorhq.com

# API Security
API_SECRET_KEY=change_this_to_a_random_secret_key
ALLOWED_ORIGINS=chrome-extension://your_extension_id,http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Phase 2A — AI Social Research + Email Drafter
# Get OpenAI API key at: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Get Serper.dev API key at: https://serper.dev (free tier: 2500 queries/month)
SERPER_API_KEY=your_serper_api_key_here

# Email drafter defaults (used when client doesn't pass these in the request)
DEFAULT_SENDER_NAME=Mai Bui
DEFAULT_SENDER_COMPANY=Your Company Name
DEFAULT_PITCH=SigninLink replaces your paper sign-in sheet with a branded QR flyer. Visitors scan, sign in, and get updates by text. You get clean digital logs, real-time records, and exportable data for compliance and marketing — no hardware required.

# Phase 2B — GHL Workflow IDs for lead tier automation (optional)
# Create workflows in GHL and paste their IDs here.
# Leave blank to disable auto-trigger for that tier.
GHL_WORKFLOW_ID_HOT=
GHL_WORKFLOW_ID_WARM=
GHL_WORKFLOW_ID_COLD=

# Phase 2B — GHL Opportunities Pipeline (optional — enables auto-create/move opportunity on classify)
# Pipeline URL: https://app.gohighlevel.com/v2/location/{LOCATION_ID}/opportunities/pipeline/{PIPELINE_ID}
# To find Stage IDs: open GHL pipeline settings → each stage has a unique ID in the URL or API response.
GHL_PIPELINE_ID=i2oUxB0CoBO1XAzDyJ9y
GHL_STAGE_ID_HOT=        # Stage ID for "Hot Lead" stage (from GHL pipeline settings)
GHL_STAGE_ID_WARM=       # Stage ID for "Warm Lead" stage
GHL_STAGE_ID_COLD=       # Stage ID for "Cold Lead" stage
#
# Multi-pipeline (optional): comma-separated values aligned by index.
# If provided, these override the single pipeline vars above.
# Example:
# GHL_PIPELINE_IDS=pipelineA,pipelineB
# GHL_STAGE_IDS_HOT=hotStageA,hotStageB
# GHL_STAGE_IDS_WARM=warmStageA,warmStageB
# GHL_STAGE_IDS_COLD=coldStageA,coldStageB
GHL_PIPELINE_IDS=
GHL_STAGE_IDS_HOT=
GHL_STAGE_IDS_WARM=
GHL_STAGE_IDS_COLD=

# Phase 3 — Webhook Security
WEBHOOK_SECRET=               # Set to a random string to secure the GHL webhook endpoint
